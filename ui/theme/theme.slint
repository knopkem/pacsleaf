// pacsleaf theme — dark-first medical imaging design language.
//
// Inspired by OHIF Viewer and KPACS-neo, optimized for radiologist workflows.

export global Theme {
    // === Color Palette ===
    out property <color> background: #0A0A0F;
    out property <color> surface: #14141A;
    out property <color> surface-elevated: #1C1C24;
    out property <color> border: #2A2A35;
    out property <color> text-primary: #F0F0F5;
    out property <color> text-secondary: #8888A0;
    out property <color> text-muted: #555570;
    out property <color> accent-primary: #1FA2D6;
    out property <color> accent-hover: #35C7FF;
    out property <color> accent-gold: #D9A03C;
    out property <color> danger: #E04040;
    out property <color> success: #40C060;
    out property <color> warning: #D9A03C;

    // === Spacing ===
    out property <length> spacing-xs: 2px;
    out property <length> spacing-sm: 4px;
    out property <length> spacing-md: 8px;
    out property <length> spacing-lg: 12px;
    out property <length> spacing-xl: 16px;
    out property <length> spacing-xxl: 24px;

    // === Border Radius ===
    out property <length> radius-sm: 4px;
    out property <length> radius-md: 6px;
    out property <length> radius-lg: 8px;

    // === Font Sizes ===
    out property <length> font-xxs: 10px;
    out property <length> font-xs: 11px;
    out property <length> font-sm: 12px;
    out property <length> font-base: 13px;
    out property <length> font-lg: 14px;
    out property <length> font-xl: 16px;
    out property <length> font-xxl: 20px;
}
