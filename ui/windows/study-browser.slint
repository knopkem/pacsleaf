// pacsleaf Study Browser Window
// Provides study search, list, and series preview for the local imagebox and remote PACS nodes.

import { Theme } from "../theme/theme.slint";
import { StatusBar } from "../components/status-bar.slint";
import { ProgressDialog } from "../components/progress-dialog.slint";
import { TextEntryDialog } from "../components/text-entry-dialog.slint";
import { ToolbarButton } from "../components/toolbar-button.slint";

// Model for a study row in the browser.
export struct StudyEntry {
    study-uid: string,
    patient-name: string,
    patient-id: string,
    study-date: string,
    modality: string,
    description: string,
    series-count: int,
    instance-count: int,
    source: string,
}

export component StudyBrowserWindow inherits Window {
    title: "pacsleaf — Study Browser";
    min-width: 900px;
    min-height: 600px;
    background: Theme.background;

    in property <[StudyEntry]> studies: [];
    in property <string> connection-status: "Disconnected";
    in-out property <bool> network-mode: false;
    in-out property <bool> settings-visible: false;
    in-out property <string> node-name: "";
    in-out property <string> local-ae-title: "";
    in-out property <string> dimse-host: "";
    in-out property <string> dimse-port: "";
    in-out property <string> remote-ae-title: "";
    in-out property <string> dicomweb-url: "";
    in-out property <string> auth-token: "";
    in property <bool> loading-visible: false;
    in property <string> loading-title: "";
    in property <string> loading-message: "";
    in property <int> loading-current: 0;
    in property <int> loading-total: 0;
    in-out property <bool> import-path-dialog-visible: false;
    in-out property <string> import-path-value: "";

    callback search(string, string, string);
    callback open-study(string);
    callback import-files();
    callback confirm-import-path(string);
    callback cancel-import-path();
    callback activate-local();
    callback activate-network();
    callback toggle-settings();
    callback save-settings(string, string, string, string, string, string, string);

    VerticalLayout {
        // Top navigation bar
        Rectangle {
            height: 48px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;

            HorizontalLayout {
                padding-left: Theme.spacing-xl;
                padding-right: Theme.spacing-xl;
                alignment: space-between;

                // App title
                HorizontalLayout {
                    spacing: Theme.spacing-md;
                    Text {
                        text: "🍃 pacsleaf";
                        color: Theme.accent-primary;
                        font-size: Theme.font-xxl;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }

                // Mode tabs
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    alignment: center;

                    Rectangle {
                        width: 80px;
                        height: 32px;
                        border-radius: Theme.radius-md;
                        background: !root.network-mode ? Theme.accent-primary : Theme.surface-elevated;
                        Text {
                            text: "Local";
                            color: !root.network-mode ? Theme.text-primary : Theme.text-secondary;
                            font-size: Theme.font-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        local-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.activate-local(); }
                        }
                    }

                    Rectangle {
                        width: 80px;
                        height: 32px;
                        border-radius: Theme.radius-md;
                        background: root.network-mode ? Theme.accent-primary : Theme.surface-elevated;
                        Text {
                            text: "Network";
                            color: root.network-mode ? Theme.text-primary : Theme.text-secondary;
                            font-size: Theme.font-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        network-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.activate-network(); }
                        }
                    }

                }

                // Settings
                Rectangle {
                    width: 40px;
                    height: 32px;
                    border-radius: Theme.radius-md;
                    background: root.settings-visible ? Theme.accent-primary : Theme.surface-elevated;

                    Text {
                        text: "⚙";
                        font-size: Theme.font-xl;
                        color: root.settings-visible ? Theme.text-primary : Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    settings-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.toggle-settings(); }
                    }
                }
            }
        }

        // Main content area
        HorizontalLayout {
            // Left: Search filters
            Rectangle {
                width: 180px;
                background: Theme.surface;
                border-width: 1px;
                border-color: Theme.border;

                VerticalLayout {
                    padding: Theme.spacing-lg;
                    spacing: Theme.spacing-sm;
                    alignment: start;

                    Text {
                        text: "Search";
                        color: Theme.text-primary;
                        font-size: Theme.font-lg;
                        font-weight: 600;
                    }

                    // Patient Name
                    Rectangle {
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-elevated;
                        border-width: 1px;
                        border-color: patient-name-input.has-focus ? Theme.accent-primary : Theme.border;

                        patient-name-input := TextInput {
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                        if patient-name-input.text == "" && !patient-name-input.has-focus: Text {
                            text: "Patient Name";
                            color: Theme.text-muted;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                        }
                    }

                    // Patient ID
                    Rectangle {
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-elevated;
                        border-width: 1px;
                        border-color: patient-id-input.has-focus ? Theme.accent-primary : Theme.border;

                        patient-id-input := TextInput {
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                        if patient-id-input.text == "" && !patient-id-input.has-focus: Text {
                            text: "Patient ID";
                            color: Theme.text-muted;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                        }
                    }

                    // Accession Number
                    Rectangle {
                        height: 32px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-elevated;
                        border-width: 1px;
                        border-color: accession-input.has-focus ? Theme.accent-primary : Theme.border;

                        accession-input := TextInput {
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                        if accession-input.text == "" && !accession-input.has-focus: Text {
                            text: "Accession #";
                            color: Theme.text-muted;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                        }
                    }

                    // Search button
                    Rectangle {
                        height: 32px;
                        border-radius: Theme.radius-md;
                        background: search-touch.has-hover ? Theme.accent-hover : Theme.accent-primary;

                        search-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.search(
                                    patient-name-input.text,
                                    patient-id-input.text,
                                    accession-input.text,
                                );
                            }
                        }
                        Text {
                            text: "Search";
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    if !root.network-mode: Rectangle {
                        height: 32px;
                        border-radius: Theme.radius-md;
                        background: import-touch.has-hover ? #ffffff10 : Theme.surface-elevated;
                        border-width: 1px;
                        border-color: Theme.border;

                        import-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.import-files(); }
                        }

                        Text {
                            text: "Import Folder…";
                            color: Theme.accent-primary;
                            font-size: Theme.font-sm;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // Center: Study list
            VerticalLayout {
                Rectangle {
                    background: Theme.background;

                    VerticalLayout {
                        // Column headers
                        Rectangle {
                            height: 32px;
                            background: Theme.surface;

                            HorizontalLayout {
                                padding-left: Theme.spacing-lg;
                                spacing: Theme.spacing-sm;

                                Text { text: "Patient"; width: 180px; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                                Text { text: "ID"; width: 100px; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                                Text { text: "Date"; width: 90px; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                                Text { text: "Mod"; width: 50px; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                                Text { text: "Description"; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                                Text { text: "Series"; width: 50px; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                            }
                        }

                        // Study rows
                        Flickable {
                            viewport-height: studies.length * 36px;

                            for study[index] in studies: Rectangle {
                                y: index * 36px;
                                height: 36px;
                                background: touch-study.has-hover ? #ffffff08 : transparent;

                                touch-study := TouchArea {
                                    double-clicked => {
                                        root.open-study(study.study-uid);
                                    }
                                }

                                HorizontalLayout {
                                    padding-left: Theme.spacing-lg;
                                    spacing: Theme.spacing-sm;

                                    Text { text: study.patient-name; width: 180px; color: Theme.text-primary; font-size: Theme.font-sm; vertical-alignment: center; overflow: elide; }
                                    Text { text: study.patient-id; width: 100px; color: Theme.text-secondary; font-size: Theme.font-sm; vertical-alignment: center; overflow: elide; }
                                    Text { text: study.study-date; width: 90px; color: Theme.text-secondary; font-size: Theme.font-sm; vertical-alignment: center; }
                                    Text { text: study.modality; width: 50px; color: Theme.accent-primary; font-size: Theme.font-sm; font-weight: 600; vertical-alignment: center; }
                                    Text { text: study.description; color: Theme.text-secondary; font-size: Theme.font-sm; vertical-alignment: center; overflow: elide; }
                                    Text { text: study.series-count; width: 50px; color: Theme.text-secondary; font-size: Theme.font-sm; vertical-alignment: center; horizontal-alignment: center; }
                                }

                                Rectangle {
                                    y: parent.height - 1px;
                                    height: 1px;
                                    background: Theme.border;
                                }
                            }
                        }
                    }
                }
            }

            if settings-visible: Rectangle {
                width: 280px;
                background: Theme.surface;
                border-width: 1px;
                border-color: Theme.border;

                Flickable {
                    viewport-height: 620px;

                    VerticalLayout {
                        width: parent.width;
                        padding: Theme.spacing-lg;
                        spacing: Theme.spacing-sm;
                        alignment: start;

                        Text {
                            text: "Network";
                            color: Theme.text-primary;
                            font-size: Theme.font-lg;
                            font-weight: 600;
                        }

                        // PACS node name
                        Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface-elevated;
                            border-width: 1px;
                            border-color: node-name-input.has-focus ? Theme.accent-primary : Theme.border;

                            node-name-input := TextInput {
                                text <=> root.node-name;
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                            if node-name-input.text == "" && !node-name-input.has-focus: Text {
                                text: "PACS node name";
                                color: Theme.text-muted;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                        }

                        // DIMSE section header
                        Rectangle {
                            height: 20px;
                            Text {
                                text: "DIMSE";
                                color: Theme.text-secondary;
                                font-size: Theme.font-xs;
                                font-weight: 600;
                                vertical-alignment: bottom;
                            }
                        }

                        Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface-elevated;
                            border-width: 1px;
                            border-color: local-ae-title-input.has-focus ? Theme.accent-primary : Theme.border;

                            local-ae-title-input := TextInput {
                                text <=> root.local-ae-title;
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                            if local-ae-title-input.text == "" && !local-ae-title-input.has-focus: Text {
                                text: "Local AE title";
                                color: Theme.text-muted;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface-elevated;
                            border-width: 1px;
                            border-color: dimse-host-input.has-focus ? Theme.accent-primary : Theme.border;

                            dimse-host-input := TextInput {
                                text <=> root.dimse-host;
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                            if dimse-host-input.text == "" && !dimse-host-input.has-focus: Text {
                                text: "Remote host";
                                color: Theme.text-muted;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface-elevated;
                            border-width: 1px;
                            border-color: dimse-port-input.has-focus ? Theme.accent-primary : Theme.border;

                            dimse-port-input := TextInput {
                                text <=> root.dimse-port;
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                            if dimse-port-input.text == "" && !dimse-port-input.has-focus: Text {
                                text: "Remote port";
                                color: Theme.text-muted;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface-elevated;
                            border-width: 1px;
                            border-color: remote-ae-title-input.has-focus ? Theme.accent-primary : Theme.border;

                            remote-ae-title-input := TextInput {
                                text <=> root.remote-ae-title;
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                            if remote-ae-title-input.text == "" && !remote-ae-title-input.has-focus: Text {
                                text: "Remote AE title";
                                color: Theme.text-muted;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                        }

                        // DICOMweb section header
                        Rectangle {
                            height: 20px;
                            Text {
                                text: "DICOMweb";
                                color: Theme.text-secondary;
                                font-size: Theme.font-xs;
                                font-weight: 600;
                                vertical-alignment: bottom;
                            }
                        }

                        Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface-elevated;
                            border-width: 1px;
                            border-color: dicomweb-url-input.has-focus ? Theme.accent-primary : Theme.border;

                            dicomweb-url-input := TextInput {
                                text <=> root.dicomweb-url;
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                            if dicomweb-url-input.text == "" && !dicomweb-url-input.has-focus: Text {
                                text: "DICOMweb URL";
                                color: Theme.text-muted;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface-elevated;
                            border-width: 1px;
                            border-color: auth-token-input.has-focus ? Theme.accent-primary : Theme.border;

                            auth-token-input := TextInput {
                                text <=> root.auth-token;
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                            if auth-token-input.text == "" && !auth-token-input.has-focus: Text {
                                text: "Bearer token";
                                color: Theme.text-muted;
                                font-size: Theme.font-sm;
                                vertical-alignment: center;
                            }
                        }

                        // Save button
                        Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-md;
                            background: save-touch.has-hover ? Theme.accent-hover : Theme.accent-primary;
                            width: 80px;

                            save-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.save-settings(
                                        node-name-input.text,
                                        local-ae-title-input.text,
                                        dimse-host-input.text,
                                        dimse-port-input.text,
                                        remote-ae-title-input.text,
                                        dicomweb-url-input.text,
                                        auth-token-input.text,
                                    );
                                }
                            }
                            Text {
                                text: "Save";
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        // Status bar
        StatusBar {
            connection-status: root.connection-status;
            study-info: studies.length == 0 ? "No studies" : studies.length == 1 ? "1 study" : "\{studies.length} studies";
        }
    }

    ProgressDialog {
        visible: root.loading-visible;
        title: root.loading-title;
        message: root.loading-message;
        progress-current: root.loading-current;
        progress-total: root.loading-total;
    }

    if root.import-path-dialog-visible: TextEntryDialog {
        title: "Import folder";
        message: "Enter a folder path on the pacsleaf host machine.";
        value <=> root.import-path-value;
        confirm-label: "Import";
        cancelled => { root.cancel-import-path(); }
        confirmed(path) => { root.confirm-import-path(path); }
    }
}
