// pacsleaf Study Browser Window
// Provides study search, list, and series preview for the local imagebox and remote PACS nodes.

import { Theme } from "../theme/theme.slint";
import { StatusBar } from "../components/status-bar.slint";
import { ToolbarButton } from "../components/toolbar-button.slint";

// Model for a study row in the browser.
export struct StudyEntry {
    study-uid: string,
    patient-name: string,
    patient-id: string,
    study-date: string,
    modality: string,
    description: string,
    series-count: int,
    instance-count: int,
    source: string,
}

export component StudyBrowserWindow inherits Window {
    title: "pacsleaf — Study Browser";
    min-width: 900px;
    min-height: 600px;
    background: Theme.background;

    in property <[StudyEntry]> studies: [];
    in property <string> connection-status: "Disconnected";
    in-out property <bool> network-mode: false;
    in-out property <bool> settings-visible: false;
    in-out property <string> node-name: "";
    in-out property <string> local-ae-title: "";
    in-out property <string> dimse-host: "";
    in-out property <string> dimse-port: "";
    in-out property <string> remote-ae-title: "";
    in-out property <string> dicomweb-url: "";
    in-out property <string> auth-token: "";

    callback search(string, string, string);
    callback open-study(string);
    callback import-files();
    callback activate-local();
    callback activate-network();
    callback toggle-settings();
    callback save-settings(string, string, string, string, string, string, string);

    VerticalLayout {
        // Top navigation bar
        Rectangle {
            height: 48px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;

            HorizontalLayout {
                padding-left: Theme.spacing-xl;
                padding-right: Theme.spacing-xl;
                alignment: space-between;

                // App title
                HorizontalLayout {
                    spacing: Theme.spacing-md;
                    Text {
                        text: "🍃 pacsleaf";
                        color: Theme.accent-primary;
                        font-size: Theme.font-xxl;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }

                // Mode tabs
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    alignment: center;

                    Rectangle {
                        width: 80px;
                        height: 32px;
                        border-radius: Theme.radius-md;
                        background: !root.network-mode ? Theme.accent-primary : Theme.surface-elevated;
                        Text {
                            text: "Local";
                            color: !root.network-mode ? Theme.text-primary : Theme.text-secondary;
                            font-size: Theme.font-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        local-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.activate-local(); }
                        }
                    }

                    Rectangle {
                        width: 80px;
                        height: 32px;
                        border-radius: Theme.radius-md;
                        background: root.network-mode ? Theme.accent-primary : Theme.surface-elevated;
                        Text {
                            text: "Network";
                            color: root.network-mode ? Theme.text-primary : Theme.text-secondary;
                            font-size: Theme.font-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        network-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.activate-network(); }
                        }
                    }

                }

                // Settings
                Rectangle {
                    width: 40px;
                    height: 32px;
                    border-radius: Theme.radius-md;
                    background: root.settings-visible ? Theme.accent-primary : Theme.surface-elevated;

                    Text {
                        text: "⚙";
                        font-size: Theme.font-xl;
                        color: root.settings-visible ? Theme.text-primary : Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    settings-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.toggle-settings(); }
                    }
                }
            }
        }

        // Main content area
        HorizontalLayout {
            // Left: Search filters
            Rectangle {
                width: 220px;
                background: Theme.surface;
                border-width: 1px;
                border-color: Theme.border;

                VerticalLayout {
                    padding: Theme.spacing-lg;
                    spacing: Theme.spacing-md;

                    Text {
                        text: "Search";
                        color: Theme.text-primary;
                        font-size: Theme.font-lg;
                        font-weight: 600;
                    }

                    // Patient Name
                    VerticalLayout {
                        spacing: Theme.spacing-xs;
                        Text {
                            text: "Patient Name";
                            color: Theme.text-secondary;
                            font-size: Theme.font-xs;
                        }
                        Rectangle {
                            height: 30px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface-elevated;
                            border-width: 1px;
                            border-color: Theme.border;
                            patient-name-input := TextInput {
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Patient ID
                    VerticalLayout {
                        spacing: Theme.spacing-xs;
                        Text {
                            text: "Patient ID";
                            color: Theme.text-secondary;
                            font-size: Theme.font-xs;
                        }
                        Rectangle {
                            height: 30px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface-elevated;
                            border-width: 1px;
                            border-color: Theme.border;
                            patient-id-input := TextInput {
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Accession Number
                    VerticalLayout {
                        spacing: Theme.spacing-xs;
                        Text {
                            text: "Accession #";
                            color: Theme.text-secondary;
                            font-size: Theme.font-xs;
                        }
                        Rectangle {
                            height: 30px;
                            border-radius: Theme.radius-sm;
                            background: Theme.surface-elevated;
                            border-width: 1px;
                            border-color: Theme.border;
                            accession-input := TextInput {
                                color: Theme.text-primary;
                                font-size: Theme.font-sm;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Search button
                    Rectangle {
                        height: 36px;
                        border-radius: Theme.radius-md;
                        background: Theme.accent-primary;
                        TouchArea {
                            clicked => {
                                root.search(
                                    patient-name-input.text,
                                    patient-id-input.text,
                                    accession-input.text,
                                );
                            }
                        }
                        Text {
                            text: "Search";
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    if !root.network-mode: Rectangle {
                        height: 36px;
                        border-radius: Theme.radius-md;
                        background: import-touch.has-hover ? #ffffff10 : Theme.surface-elevated;
                        border-width: 1px;
                        border-color: Theme.border;

                        import-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.import-files(); }
                        }

                        Text {
                            text: "Import Folder...";
                            color: Theme.accent-primary;
                            font-size: Theme.font-sm;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // Center: Study list
            VerticalLayout {
                Rectangle {
                    background: Theme.background;

                    VerticalLayout {
                        // Column headers
                        Rectangle {
                            height: 32px;
                            background: Theme.surface;

                            HorizontalLayout {
                                padding-left: Theme.spacing-lg;
                                spacing: Theme.spacing-sm;

                                Text { text: "Patient"; width: 180px; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                                Text { text: "ID"; width: 100px; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                                Text { text: "Date"; width: 90px; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                                Text { text: "Mod"; width: 50px; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                                Text { text: "Description"; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                                Text { text: "Series"; width: 50px; color: Theme.text-secondary; font-size: Theme.font-xs; font-weight: 600; vertical-alignment: center; }
                            }
                        }

                        // Study rows
                        Flickable {
                            viewport-height: studies.length * 36px;

                            for study[index] in studies: Rectangle {
                                y: index * 36px;
                                height: 36px;
                                background: touch-study.has-hover ? #ffffff08 : transparent;

                                touch-study := TouchArea {
                                    double-clicked => {
                                        root.open-study(study.study-uid);
                                    }
                                }

                                HorizontalLayout {
                                    padding-left: Theme.spacing-lg;
                                    spacing: Theme.spacing-sm;

                                    Text { text: study.patient-name; width: 180px; color: Theme.text-primary; font-size: Theme.font-sm; vertical-alignment: center; overflow: elide; }
                                    Text { text: study.patient-id; width: 100px; color: Theme.text-secondary; font-size: Theme.font-sm; vertical-alignment: center; overflow: elide; }
                                    Text { text: study.study-date; width: 90px; color: Theme.text-secondary; font-size: Theme.font-sm; vertical-alignment: center; }
                                    Text { text: study.modality; width: 50px; color: Theme.accent-primary; font-size: Theme.font-sm; font-weight: 600; vertical-alignment: center; }
                                    Text { text: study.description; color: Theme.text-secondary; font-size: Theme.font-sm; vertical-alignment: center; overflow: elide; }
                                    Text { text: study.series-count; width: 50px; color: Theme.text-secondary; font-size: Theme.font-sm; vertical-alignment: center; horizontal-alignment: center; }
                                }

                                Rectangle {
                                    y: parent.height - 1px;
                                    height: 1px;
                                    background: Theme.border;
                                }
                            }
                        }
                    }
                }
            }

            if settings-visible: Rectangle {
                width: 300px;
                background: Theme.surface;
                border-width: 1px;
                border-color: Theme.border;

                VerticalLayout {
                    padding: Theme.spacing-lg;
                    spacing: Theme.spacing-md;

                    Text {
                        text: "Network";
                        color: Theme.text-primary;
                        font-size: Theme.font-lg;
                        font-weight: 600;
                    }

                    Text {
                        text: "PACS node name";
                        color: Theme.text-secondary;
                        font-size: Theme.font-xs;
                    }
                    Rectangle {
                        height: 34px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-elevated;
                        border-width: 1px;
                        border-color: Theme.border;
                        node-name-input := TextInput {
                            text <=> root.node-name;
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "DIMSE";
                        color: Theme.text-primary;
                        font-size: Theme.font-sm;
                        font-weight: 600;
                    }

                    Text {
                        text: "Local AE title";
                        color: Theme.text-secondary;
                        font-size: Theme.font-xs;
                    }
                    Rectangle {
                        height: 34px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-elevated;
                        border-width: 1px;
                        border-color: Theme.border;
                        local-ae-title-input := TextInput {
                            text <=> root.local-ae-title;
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "Remote host";
                        color: Theme.text-secondary;
                        font-size: Theme.font-xs;
                    }
                    Rectangle {
                        height: 34px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-elevated;
                        border-width: 1px;
                        border-color: Theme.border;
                        dimse-host-input := TextInput {
                            text <=> root.dimse-host;
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "Remote port";
                        color: Theme.text-secondary;
                        font-size: Theme.font-xs;
                    }
                    Rectangle {
                        height: 34px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-elevated;
                        border-width: 1px;
                        border-color: Theme.border;
                        dimse-port-input := TextInput {
                            text <=> root.dimse-port;
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "Remote AE title";
                        color: Theme.text-secondary;
                        font-size: Theme.font-xs;
                    }
                    Rectangle {
                        height: 34px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-elevated;
                        border-width: 1px;
                        border-color: Theme.border;
                        remote-ae-title-input := TextInput {
                            text <=> root.remote-ae-title;
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "DICOMweb";
                        color: Theme.text-primary;
                        font-size: Theme.font-sm;
                        font-weight: 600;
                    }

                    Text {
                        text: "DICOMweb URL";
                        color: Theme.text-secondary;
                        font-size: Theme.font-xs;
                    }
                    Rectangle {
                        height: 34px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-elevated;
                        border-width: 1px;
                        border-color: Theme.border;
                        dicomweb-url-input := TextInput {
                            text <=> root.dicomweb-url;
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "Bearer token";
                        color: Theme.text-secondary;
                        font-size: Theme.font-xs;
                    }
                    Rectangle {
                        height: 34px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-elevated;
                        border-width: 1px;
                        border-color: Theme.border;
                        auth-token-input := TextInput {
                            text <=> root.auth-token;
                            color: Theme.text-primary;
                            font-size: Theme.font-sm;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle { }

                    ToolbarButton {
                        width: 84px;
                        label: "Save";
                        active: true;
                        clicked => {
                            root.save-settings(
                                node-name-input.text,
                                local-ae-title-input.text,
                                dimse-host-input.text,
                                dimse-port-input.text,
                                remote-ae-title-input.text,
                                dicomweb-url-input.text,
                                auth-token-input.text,
                            );
                        }
                    }
                }
            }
        }

        // Status bar
        StatusBar {
            connection-status: root.connection-status;
            study-info: studies.length == 0 ? "No studies" : studies.length == 1 ? "1 study" : "\{studies.length} studies";
        }
    }
}
